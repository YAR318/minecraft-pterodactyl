# ==============================================
# .gitignore - Pterodactyl & Minecraft Project
# ==============================================

# ── Secrets y variables de entorno ──────────
.env
*.env
.env.*
secrets/
credentials/

# ── Configuración real de Wings (tiene tokens) ──
config/wings/config.yml

# ── Logs ────────────────────────────────────
*.log
logs/

# ── Archivos temporales y caché ─────────────
*.tmp
*.cache
*.swp
*~
.DS_Store
Thumbs.db

# ── Scripts de instalación descargados ──────
install.sh

# ── Certificados SSL ─────────────────────────
*.pem
*.key
*.crt
*.p12

# ── Docker volumes locales ───────────────────
volumes/
docker-volumes/

# ── Dependencias ────────────────────────────
node_modules/
npm-debug.log*
vendor/

# ── Backups ──────────────────────────────────
*.bak
backups/
