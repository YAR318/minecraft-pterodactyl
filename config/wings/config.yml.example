# ──────────────────────────────────────────────────────────────
# Wings — Template de Configuración
# Copia a /etc/pterodactyl/config.yml en el servidor
# El valor real se obtiene desde el panel al crear el nodo
# ──────────────────────────────────────────────────────────────
# NO editar manualmente — usar el "Auto Deploy" del panel
# Admin → Nodes → [Nodo] → Configuration → Auto-Deploy
# ──────────────────────────────────────────────────────────────

debug: false
app_name: "Pterodactyl"
uuid: ""         # Generado automáticamente por el panel
token_id: ""     # Generado automáticamente por el panel
token: ""        # Generado automáticamente por el panel

api:
  host: "0.0.0.0"
  port: 8080
  ssl:
    enabled: true
    cert: /etc/letsencrypt/live/panel.yeremi.work/fullchain.pem
    key: /etc/letsencrypt/live/panel.yeremi.work/privkey.pem
  upload_limit: 1024

system:
  data: /var/lib/pterodactyl/volumes
  sftp:
    bind_port: 2022

remote: "https://panel.yeremi.work"
