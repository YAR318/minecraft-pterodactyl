# =============================================================
# Variables de Entorno — Pterodactyl + Minecraft
# Copia este archivo: cp .env.example .env
# Nunca subas el .env real a Git
# =============================================================

# ── Aplicación ──────────────────────────────────────────────
APP_URL=https://panel.yeremi.work
APP_TIMEZONE=America/Tegucigalpa

# ── Base de datos ────────────────────────────────────────────
DB_ROOT_PASSWORD=cambia_esta_password_root
DB_DATABASE=panel
DB_USERNAME=pterodactyl
DB_PASSWORD=cambia_esta_password_db

# ── Administrador inicial del panel ──────────────────────────
# (Solo se usa en el primer arranque)
PANEL_ADMIN_EMAIL=admin@yeremi.work
PANEL_ADMIN_USERNAME=Maru
PANEL_ADMIN_FIRSTNAME=Yeremi
PANEL_ADMIN_LASTNAME=Gomez
PANEL_ADMIN_PASSWORD=cambia_esta_password_admin

# ── Correo (opcional, dejar en log para desarrollo) ──────────
MAIL_DRIVER=log
MAIL_FROM=admin@yeremi.work
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
